{
  "name": "jd-clinic-booking-skills",
  "title": "JD皮肤科预约 JD Clinic Booking Skills",
  "version": "1.0.0",
  "tags": [
    "JD皮肤科",
    "JD Clinic",
    "韩国",
    "皮肤科",
    "首尔",
    "江南",
    "医美预约",
    "韩国皮肤管理",
    "水光针",
    "激光美容",
    "韩国医美",
    "Korea",
    "dermatology",
    "Seoul",
    "Gangnam",
    "jd-clinic",
    "booking-skills",
    "JD Clinic预约"
  ],
  "description": "JD皮肤科+更多医院独立预约技能合集 — 韩国首尔人气皮肤科预约助手",
  "permissions": {
    "network": [
      "https://api.yestokr.com/api/Appointment/saveFromSkill",
      "https://i.beautsgo.com/*",
      "https://apis.beise.com:50144/*"
    ],
    "filesystem": false
  },
  "privacy": {
    "data_collected": [
      "用户提供的手机号（联系方式），仅在用户明确同意后发送至 BeautsGO 预约接口"
    ],
    "data_sent_to": [
      {
        "name": "BeautsGO 预约接口",
        "url": "https://api.yestokr.com/api/Appointment/saveFromSkill",
        "purpose": "提交 JD皮肤科 预约申请",
        "when": "仅当用户主动发起「帮我预约」并提供联系方式时"
      }
    ],
    "no_data_stored": true,
    "no_tracking": true
  },
  "runtime": {
    "requires": {
      "node": ">=16"
    }
  },
  "entry": "api/skill.js",
  "input": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "用户输入：初次访问显示预约指南，或后续操作（'打开链接'/'帮我预约'/'咨询客服'/'查价格'/'2人 3月26日' 等）"
      },
      "lang": {
        "type": "string",
        "description": "语言代码（zh/en），默认zh",
        "default": "zh"
      },
      "context": {
        "type": "object",
        "description": "多轮对话上下文（可选），用于跨轮保持状态"
      }
    },
    "required": [
      "query"
    ]
  },
  "output": {
    "type": "string",
    "description": "第1轮：预约指南+操作建议；后续：预约提交/价格查询/客服对话等结果"
  }
}
